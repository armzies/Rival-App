rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'elo', 'matchesPlayed', 'wins', 'losses', 'createdAt', 'isGuest', 'hostId']) &&
             data.uid is string &&
             (data.email is string || data.email == null) &&
             (data.displayName is string || data.displayName == null) &&
             (data.photoURL is string || data.photoURL == null) &&
             data.elo is number &&
             data.matchesPlayed is number &&
             data.wins is number &&
             data.losses is number &&
             data.createdAt is timestamp &&
             (!('isGuest' in data) || data.isGuest is bool) &&
             (!('hostId' in data) || data.hostId is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && (!('isGuest' in request.resource.data) || request.resource.data.isGuest == false)) ||
        (request.resource.data.isGuest == true && request.resource.data.hostId == request.auth.uid)
      );
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isOwner(userId) ||
        (resource.data.isGuest == true && resource.data.hostId == request.auth.uid)
      );
    }

    match /matches/{matchId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && request.resource.data.loggedBy == request.auth.uid;
      
      // Allow updating matches (for resolving pending matches in a session)
      allow update: if isAuthenticated() && (
        // Either the user logged it, or they are updating a session match
        request.resource.data.loggedBy == request.auth.uid ||
        ('sessionId' in resource.data && resource.data.sessionId != null)
      );
      
      allow delete: if isAuthenticated() && resource.data.loggedBy == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players']))
      );
      
      allow delete: if false;
    }
  }
}
